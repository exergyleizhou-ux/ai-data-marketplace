# Production environment — copy to .env.prod and fill in. NEVER commit .env.prod.
#   cp .env.prod.example .env.prod && $EDITOR .env.prod

# --- Domain (Caddy gets a TLS cert for this automatically) ---
# Use a real domain pointed at this host for HTTPS. For a local trial use "localhost".
DOMAIN=example.com

# --- Postgres ---
POSTGRES_USER=app
POSTGRES_DB=ai_data_marketplace
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# --- Secrets (generate fresh, never reuse the examples) ---
# openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_hex_chars
# openssl rand -hex 32   (encrypts stored ID numbers at rest)
PII_SECRET=CHANGE_ME_64_hex_chars
# protects the /metrics endpoint; openssl rand -hex 16
METRICS_TOKEN=CHANGE_ME_metrics_token

# --- Object storage (MinIO, S3-compatible — swap creds for AWS S3 / Aliyun OSS /
#     Tencent COS by changing S3_ENDPOINT in docker-compose.prod.yml) ---
MINIO_ROOT_USER=oasis
# openssl rand -hex 20
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
S3_BUCKET=ai-data-marketplace

# --- Payments ---
# "mock"   = sandbox, no real funds (default; safe for demos and internal trials)
# "stripe" = real money via Stripe (test or live keys below)
PAYMENT_PROVIDER=mock
# Used only when PAYMENT_PROVIDER=mock (signs the dev mark-paid flow).
PAYMENT_MOCK_SECRET=CHANGE_ME_mock_secret
# Used only when PAYMENT_PROVIDER=stripe:
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_CURRENCY=usd

# NOTE: real WeChat/Alipay split settlement for the Chinese market needs a
# LICENSED payment provider + fund custody. That is a legal/commercial gate, not
# a configuration one — keep PAYMENT_PROVIDER=mock until that is in place.
