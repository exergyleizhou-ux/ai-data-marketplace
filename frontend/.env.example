# Base URL of the backend API, consumed by the frontend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# Stripe publishable key (pk_test_… in test mode). Safe to ship to the browser —
# it only initiates payments; charges are authorised server-side via the secret
# key. Leave blank to fall back to the sandbox "mark paid" button.
# Copy this file's real value into .env.local (gitignored) for local testing.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
