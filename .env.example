# Copy to .env and adjust. NEVER commit a real .env.
# docker-compose.yml sets these for the containerized stack; this file is for
# running backend/frontend directly on the host.

# --- backend ---
APP_ENV=development
HTTP_ADDR=:8080
DATABASE_URL=postgres://app:app@localhost:5432/ai_data_marketplace?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# --- frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# --- object storage ---
STORAGE_DRIVER=local            # local (dev, filesystem) | s3 (MinIO/AWS S3/Aliyun OSS/Tencent COS)
STORAGE_DIR=./data/storage      # base dir for the local driver
# s3 driver (works with free self-hosted MinIO and any S3-compatible cloud):
S3_ENDPOINT=localhost:9000      # host:port, no scheme
S3_BUCKET=ai-data-marketplace
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false                # true for cloud endpoints
S3_REGION=us-east-1
# For Aliyun OSS / Tencent COS: set S3_ENDPOINT to their S3-compatible endpoint,
# S3_USE_SSL=true, and the access key/secret from the cloud console.

# --- secrets (override in staging/production; keep out of git) ---
# JWT_SECRET=
# PII_SECRET=

# --- payment (sandbox by default; real = Spike-2 + 法务, docs §2.1) ---
PAYMENT_PROVIDER=mock           # mock (sandbox) | wechat | alipay | stripe
PAYMENT_MOCK_SECRET=dev-pay-secret
